DATABASE_URL=
JWT_SECRET=
JWT_EXPIRE_MINUTES=
JWT_REFRESH_EXPIRE_DAYS=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
FRONTEND_URL=
ALLOWED_ORIGINS=["http://localhost:3000"]

ANTHROPIC_API_KEY=

LLM_KEY_ENCRYPTION_SECRET=

# Redis — rate limiting + email tokens
# Upstash: rediss://default:<password>@<host>.upstash.io:6379
# Leave empty to use in-memory fallback (development only)
REDIS_URL=

RATE_LIMIT_ENABLED=true

# SMTP (Gmail App Password 사용)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM_NAME=Marginalia

# Password policy
PASSWORD_MIN_LENGTH=8
# PASSWORD_REQUIRE_LETTER=true
# PASSWORD_REQUIRE_DIGIT=true

# Cookie settings
# COOKIE_SECURE=true          # 로컬: false (기본값), 프로덕션: true
# COOKIE_SAMESITE=none        # 동일 도메인: lax (기본값), 크로스 도메인: none (Secure 필수)
# COOKIE_DOMAIN=.example.com  # 서브도메인 공유 시 설정

# Monitoring (GlitchTip / Sentry) — 비우면 비활성화
SENTRY_DSN=
ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.01
